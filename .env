# ─────────────────────────────────────────────────────────────
# Local Development Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# SQLite for local development (no Postgres needed locally)
# On Railway, this is auto-replaced by the PostgreSQL URL from the Postgres plugin
DATABASE_URL="file:./dev.db"

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBW9qY_8dp_FISyQsNVCqTk_sh5N5alnNg

# Better Auth secret — MUST match what was used when the admin was seeded
BETTER_AUTH_SECRET="dev-secret-string-12345"

# Public-facing app URL (used by auth client)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal URL used by Better Auth server (same as app URL in dev)
BETTER_AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────
# Admin Seeding (used by: npx tsx seed.ts)
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="demo@audiotranscriber.com"
ADMIN_PASSWORD="AudioDemo2026!"