# ─────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in your values
# This file is safe to commit (no real secrets).
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Google Gemini API key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Better Auth secret — run: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Your deployed app URL (Railway provides this)
NEXT_PUBLIC_APP_URL="https://your-app.railway.app"
BETTER_AUTH_URL="https://your-app.railway.app"

# Admin credentials for seeding (only used during setup)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""
